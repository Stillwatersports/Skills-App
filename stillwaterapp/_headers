# Netlify security headers — applied to all pages
/*
  # Prevent clickjacking — stops your app being embedded in iframes on other sites
  X-Frame-Options: DENY

  # Stop browsers guessing content types (prevents certain injection attacks)
  X-Content-Type-Options: nosniff

  # Controls how much referrer info is sent when navigating away
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser APIs — only enable what the app actually uses
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(), usb=()

  # Force HTTPS for 1 year — browsers will refuse to load over HTTP
  Strict-Transport-Security: max-age=31536000; includeSubDomains

  # Content Security Policy — controls what resources the app can load
  # Allows: your own domain, Supabase, Google auth, Google Fonts, your GitHub-hosted assets
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://*.supabase.co https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://raw.githubusercontent.com https://lh3.googleusercontent.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://accounts.google.com; frame-src https://accounts.google.com; object-src 'none'; base-uri 'self'; form-action 'self'

  # XSS protection for older browsers
  X-XSS-Protection: 1; mode=block
